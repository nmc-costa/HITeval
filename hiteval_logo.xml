<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <defs>
    <!-- Gradiente de Fundo (Azul Tecnológico) -->
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e3a8a" /> <!-- Slate/Blue escuro -->
      <stop offset="100%" stop-color="#3b82f6" /> <!-- Azul vivo -->
    </linearGradient>
    
    <!-- Gradiente da Área de Performance (Verde Sucesso/Crescimento) -->
    <linearGradient id="area" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#34d399" stop-opacity="0.85" />
      <stop offset="100%" stop-color="#10b981" stop-opacity="0.85" />
    </linearGradient>
  </defs>
  
  <!-- Base do Logo: Quadrado com cantos redondos -->
  <rect x="32" y="32" width="448" height="448" rx="100" fill="url(#bg)" />
  
  <!-- Anéis do Radar (Fundo) -->
  <circle cx="256" cy="256" r="160" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="4" stroke-dasharray="8 8"/>
  <circle cx="256" cy="256" r="90" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="4" stroke-dasharray="8 8"/>
  
  <!-- Eixos do Radar -->
  <line x1="256" y1="76" x2="256" y2="436" stroke="rgba(255,255,255,0.15)" stroke-width="4"/>
  <line x1="76" y1="256" x2="436" y2="256" stroke="rgba(255,255,255,0.15)" stroke-width="4"/>
  <line x1="128" y1="128" x2="384" y2="384" stroke="rgba(255,255,255,0.15)" stroke-width="4"/>
  <line x1="128" y1="384" x2="384" y2="128" stroke="rgba(255,255,255,0.15)" stroke-width="4"/>
  
  <!-- Polígono da Performance (Simulando uma boa avaliação/evolução) -->
  <polygon points="256,110 360,170 380,280 290,390 170,350 120,256 160,150" fill="url(#area)" stroke="#059669" stroke-width="6" stroke-linejoin="round"/>
  
  <!-- Nós/Pontos de Métrica -->
  <circle cx="256" cy="110" r="12" fill="#ffffff" />
  <circle cx="360" cy="170" r="12" fill="#ffffff" />
  <circle cx="380" cy="280" r="12" fill="#ffffff" />
  <circle cx="290" cy="390" r="12" fill="#ffffff" />
  <circle cx="170" cy="350" r="12" fill="#ffffff" />
  <circle cx="120" cy="256" r="12" fill="#ffffff" />
  <circle cx="160" cy="150" r="12" fill="#ffffff" />
  
  <!-- Centro / Alvo (Representando o "🎯 HITeval") -->
  <circle cx="256" cy="256" r="16" fill="#fcd34d" />
  <circle cx="256" cy="256" r="6" fill="#ffffff" />
</svg>